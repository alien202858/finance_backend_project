{
  "info": {
    "name": "Finance Backend API",
    "_postman_id": "finance-backend",
    "description": "Postman collection for Finance Backend APIs",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Register",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Admin\",\n  \"email\": \"admin@test.com\",\n  \"password\": \"123456\",\n  \"role\": \"admin\"\n}"
        },
        "url": {
          "raw": "http://localhost:5000/api/auth/register"
        }
      }
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@test.com\",\n  \"password\": \"123456\"\n}"
        },
        "url": {
          "raw": "http://localhost:5000/api/auth/login"
        }
      }
    },
    {
      "name": "Create Record",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "{{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"amount\": 5000,\n  \"type\": \"income\",\n  \"category\": \"salary\",\n  \"note\": \"monthly salary\"\n}"
        },
        "url": {
          "raw": "http://localhost:5000/api/records"
        }
      }
    },
    {
      "name": "Get Records",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "{{token}}" }
        ],
        "url": {
          "raw": "http://localhost:5000/api/records"
        }
      }
    },
    {
      "name": "Dashboard Summary",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "{{token}}" }
        ],
        "url": {
          "raw": "http://localhost:5000/api/dashboard/summary"
        }
      }
    }
  ],
  "variable": [
    {
      "key": "token",
      "value": ""
    }
  ]
}